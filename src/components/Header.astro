---
const path = Astro.url.pathname;
const cur = (p: string) => (path === p || (p !== '/' && path.startsWith(p)) ? 'page' : undefined);
---
<header class="site-header wrap">
  <a class="wordmark" href="/">BILAL ABBOUD</a>
  <nav class="nav" aria-label="Main">
    <a href="/projects/" aria-current={cur('/projects/')}>PROJECTS</a>
    <a href="/tools/" aria-current={cur('/tools/')}>TOOLS</a>
    <a href="/about/" aria-current={cur('/about/')}>ABOUT</a>
  </nav>
</header>
