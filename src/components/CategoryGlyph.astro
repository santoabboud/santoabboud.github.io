---
/** Fallback card art when a project has no cover: line-art glyph per
 *  category, drawn from theme tokens so it re-skins with the site. */
const { category } = Astro.props;
---
{category === 'spectroscopy' ? (
<svg viewBox="0 0 320 180" aria-hidden="true">
  <line x1="20" y1="150" x2="300" y2="150" stroke="var(--line)" stroke-width="2"/>
  <line x1="56" y1="150" x2="56" y2="96" stroke="var(--w-405)" stroke-width="3"/>
  <line x1="92" y1="150" x2="92" y2="118" stroke="var(--muted)" stroke-width="2"/>
  <line x1="118" y1="150" x2="118" y2="58" stroke="var(--w-488)" stroke-width="3"/>
  <line x1="142" y1="150" x2="142" y2="104" stroke="var(--muted)" stroke-width="2"/>
  <line x1="168" y1="150" x2="168" y2="34" stroke="var(--w-511)" stroke-width="3"/>
  <line x1="206" y1="150" x2="206" y2="92" stroke="var(--w-578)" stroke-width="3"/>
  <line x1="232" y1="150" x2="232" y2="124" stroke="var(--muted)" stroke-width="2"/>
  <line x1="262" y1="150" x2="262" y2="70" stroke="var(--w-633)" stroke-width="3"/>
</svg>
) : category === 'microscopy' ? (
<svg viewBox="0 0 320 180" aria-hidden="true">
  <circle cx="160" cy="90" r="58" fill="none" stroke="var(--line)" stroke-width="2"/>
  <circle cx="160" cy="90" r="38" fill="none" stroke="var(--muted)" stroke-width="1.5"/>
  <circle cx="160" cy="90" r="16" fill="none" stroke="var(--acc)" stroke-width="2"/>
  <line x1="160" y1="14" x2="160" y2="46" stroke="var(--muted)" stroke-width="1.5"/>
  <line x1="160" y1="134" x2="160" y2="166" stroke="var(--muted)" stroke-width="1.5"/>
  <line x1="84" y1="90" x2="116" y2="90" stroke="var(--muted)" stroke-width="1.5"/>
  <line x1="204" y1="90" x2="236" y2="90" stroke="var(--muted)" stroke-width="1.5"/>
  <circle cx="160" cy="90" r="3" fill="var(--mark-bright)"/>
</svg>
) : category === 'lasers' ? (
<svg viewBox="0 0 320 180" aria-hidden="true">
  <rect x="34" y="74" width="74" height="32" rx="4" fill="none" stroke="var(--muted)" stroke-width="2"/>
  <line x1="108" y1="90" x2="190" y2="90" stroke="var(--w-633)" stroke-width="3"/>
  <rect x="190" y="76" width="10" height="28" fill="none" stroke="var(--acc)" stroke-width="2" transform="rotate(20 195 90)"/>
  <line x1="202" y1="86" x2="286" y2="62" stroke="var(--w-511)" stroke-width="3"/>
  <line x1="202" y1="94" x2="286" y2="118" stroke="var(--w-633)" stroke-width="2" stroke-dasharray="5 4"/>
</svg>
) : category === 'night-vision' ? (
<svg viewBox="0 0 320 180" aria-hidden="true">
  <circle cx="160" cy="90" r="56" fill="none" stroke="var(--muted)" stroke-width="2"/>
  <circle cx="160" cy="90" r="44" fill="none" stroke="var(--line)" stroke-width="1.5"/>
  <path d="M116 90 a44 44 0 0 1 88 0" fill="none" stroke="var(--acc)" stroke-width="2"/>
  <circle cx="160" cy="90" r="5" fill="var(--acc)"/>
  <line x1="160" y1="34" x2="160" y2="20" stroke="var(--muted)" stroke-width="2"/>
</svg>
) : category === 'cameras' ? (
<svg viewBox="0 0 320 180" aria-hidden="true">
  <rect x="92" y="52" width="136" height="92" rx="8" fill="none" stroke="var(--muted)" stroke-width="2"/>
  <circle cx="160" cy="98" r="30" fill="none" stroke="var(--acc)" stroke-width="2"/>
  <circle cx="160" cy="98" r="14" fill="none" stroke="var(--line)" stroke-width="2"/>
  <rect x="124" y="40" width="36" height="12" rx="3" fill="none" stroke="var(--muted)" stroke-width="2"/>
  <circle cx="212" cy="68" r="4" fill="var(--mark-bright)"/>
</svg>
) : category === 'batteries' ? (
<svg viewBox="0 0 320 180" aria-hidden="true">
  <rect x="96" y="62" width="116" height="56" rx="8" fill="none" stroke="var(--muted)" stroke-width="2"/>
  <rect x="212" y="78" width="14" height="24" rx="3" fill="none" stroke="var(--muted)" stroke-width="2"/>
  <rect x="104" y="70" width="38" height="40" rx="4" fill="var(--acc)" opacity=".55"/>
  <rect x="146" y="70" width="24" height="40" rx="4" fill="var(--acc)" opacity=".3"/>
  <path d="M168 56 l-12 28 h14 l-12 28" fill="none" stroke="var(--mark-bright)" stroke-width="2.5"/>
</svg>
) : category === 'simulation-software' ? (
<svg viewBox="0 0 320 180" aria-hidden="true">
  <polyline points="30,150 70,150 95,60 120,130 145,90 170,118 290,118" fill="none" stroke="var(--acc)" stroke-width="2.5"/>
  <line x1="30" y1="150" x2="290" y2="150" stroke="var(--line)" stroke-width="2"/>
  <line x1="30" y1="30" x2="30" y2="150" stroke="var(--line)" stroke-width="2"/>
  <g fill="var(--muted)"><circle cx="95" cy="60" r="3"/><circle cx="145" cy="90" r="3"/><circle cx="170" cy="118" r="3"/></g>
</svg>
) : (
<svg viewBox="0 0 320 180" aria-hidden="true">
  <path d="M70 130 q50 -90 90 -40 q40 50 90 -28" fill="none" stroke="var(--acc)" stroke-width="2.5"/>
  <circle cx="70" cy="130" r="4" fill="var(--mark-bright)"/>
  <circle cx="250" cy="62" r="4" fill="var(--mark-bright)"/>
</svg>
)}
