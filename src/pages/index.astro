---
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import { SITE } from '../config';

const projects = (await getCollection('projects', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const featured = projects.slice(0, 6);
---
<Base>
  <section class="hero">
    <p class="eyebrow">{SITE.eyebrow}</p>
    <h1>Multidisciplinary R&amp;D scientist &amp; engineer.</h1>
    <p class="bio">{SITE.bio.replace('Multidisciplinary R&D scientist & engineer experienced in ', 'Experienced in ')}</p>
    <div class="spectral" aria-hidden="true">
      <div class="spectral-bar">
        <i class="tick" style="left:7.8%"><span>405</span></i>
        <i class="tick" style="left:47.5%"><span>532</span></i>
        <i class="tick" style="left:79.1%"><span>633</span></i>
      </div>
      <div class="spectral-cap"><span>380 nm</span><span>Nd:YAG · 1064 → 532 → 266 nm</span><span>700 nm</span></div>
    </div>
  </section>

  <p class="section-label"><span class="n">01</span> Selected work <a href="/projects/">All projects →</a></p>
  <section class="grid">
    {featured.map((p) => <ProjectCard project={p} />)}
  </section>

  <p class="section-label"><span class="n">02</span> Tools</p>
  <section class="grid">
    <article class="card"><a class="cardlink" href="/tools/spectra/">
      <div class="pad" style="padding-top:16px">
        <span class="tag">TOOL</span>
        <h3>Atomic Spectra Viewer</h3>
        <p>143,786 NIST lines across 549 species. Periodic-table selection, ionization-stage filters, line finder.</p>
      </div></a>
    </article>
    <article class="card"><a class="cardlink" href="/tools/calibration/">
      <div class="pad" style="padding-top:16px">
        <span class="tag">TOOL</span>
        <h3>Spectrometer Calibration Calculator</h3>
        <p>Pixel→wavelength polynomial fits in a numerically stable basis, with coefficient uncertainties.</p>
      </div></a>
    </article>
    <article class="card"><a class="cardlink" href="/tools/libs/">
      <div class="pad" style="padding-top:16px">
        <span class="tag">TOOL</span>
        <h3>LIBS Analyzer</h3>
        <p>Laser-induced breakdown spectroscopy: NIST line matching, transparent elemental confidence, plasma temperature, and calibration-free composition. All client-side.</p>
      </div></a>
    </article>
  </section>
</Base>
